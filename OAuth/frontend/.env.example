# OAuth 2.0 Demo - Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# API Configuration
# ============================================

# Backend API base URL
VITE_API_URL=http://localhost:8090

# ============================================
# Security Notes
# ============================================
# 1. This file only contains public configuration
# 2. Never store secrets in .env files - they are bundled with the app
# 3. The actual JWT secret is stored server-side
# 4. All authentication is handled via httpOnly cookies
